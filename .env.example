# Clé secrète Notion — Créer une intégration sur https://www.notion.so/my-integrations
# Doit avoir les permissions : Read/Update/Insert content + Read/Update databases
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la page Notion où créer le Second Brain
# Obtenir depuis l'URL de la page : notion.so/[workspace]/[PAGE_ID]?...
# Format sans tirets (32 caractères hexadécimaux) ou avec tirets (UUID)
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
